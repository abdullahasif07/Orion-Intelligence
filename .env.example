# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Tools ---
# https://newsapi.org/  (free tier: 100 req/day, developer key)
NEWSAPI_KEY=

# https://openweathermap.org/api  (free tier)
OPENWEATHERMAP_API_KEY=

# https://brave.com/search/api/  (free tier: 2k req/month)
BRAVE_SEARCH_API_KEY=

# --- Agent loop ---
MAX_AGENT_ITERATIONS=5
TOOL_TIMEOUT_SECONDS=15
TOOL_CACHE_TTL_SECONDS=60

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
